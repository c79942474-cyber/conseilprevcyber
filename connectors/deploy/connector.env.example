# Configuration du connecteur — copier en /etc/conseilprev/connector.env
# et renseigner les valeurs. Ce fichier contient un SECRET : chmod 600, jamais versionné.

# --- Cible : l'instance du site qui reçoit les événements --------------------
# En production, une instance PRIVÉE (pas la démo publique). Voir DEPLOY.md.
COCKPIT_URL=https://cockpit.interne.exemple

# Jeton d'ingestion — identique à INGEST_TOKEN côté serveur (en-tête X-Ingest-Token).
INGEST_TOKEN=CHANGEZ-MOI

# --- Source : la plateforme OT à interroger ---------------------------------
OT_API_URL=https://plateforme-ot.interne/api/alerts
OT_API_TOKEN=jeton-lecture-seule-de-la-plateforme

# Chemin JSON de la liste d'alertes dans la réponse (ex. result, data.alerts…).
OT_ALERTS_PATH=alerts

# Intervalle d'interrogation en secondes.
OT_INTERVAL=10
